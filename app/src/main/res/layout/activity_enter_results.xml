<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Header -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@color/teacher_primary">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enter Results"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvExamTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Exam"
                android:textColor="#B2DFDB"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Filters -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@color/white">

        <!-- Section Selector (Pre-Primary / Primary) -->
        <Spinner
            android:id="@+id/spinnerSection"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/spinner_bg"
            android:padding="8dp"
            android:layout_marginBottom="8dp" />

        <!-- Exam Type -->
        <Spinner
            android:id="@+id/spinnerExam"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/spinner_bg"
            android:padding="8dp"
            android:layout_marginBottom="8dp" />

        <!-- Class/Level -->
        <Spinner
            android:id="@+id/spinnerClass"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/spinner_bg"
            android:padding="8dp"
            android:layout_marginBottom="8dp" />

        <!-- Subject -->
        <EditText
            android:id="@+id/editTextSubject"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/edittext_bg"
            android:hint="Enter Subject Name"
            android:padding="12dp"
            android:textSize="14sp" />

        <!-- Grading System Indicator -->
        <TextView
            android:id="@+id/tvGradingInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Grading: A(80-100) B(70-79) C(60-69) D(50-59) E(0-49)"
            android:textColor="#666666"
            android:textSize="12sp"
            android:background="#F5F5F5"
            android:padding="8dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Student List -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_margin="8dp"
        app:cardCornerRadius="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Stats Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:background="#F5F5F5">

                <TextView
                    android:id="@+id/tvTotalStudents"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Total: 0 students"
                    android:textColor="#1A1A2E"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvEnteredCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Entered: 0/0"
                    android:textColor="#FF9800"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Progress Bar -->
            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <!-- Empty State -->
            <TextView
                android:id="@+id/tvEmptyState"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="Select section, class and subject to load students"
                android:textColor="#666666"
                android:textSize="14sp"
                android:visibility="gone" />

            <!-- RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvStudents"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="4dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@color/white">

        <!-- Cancel Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Cancel"
            android:textSize="24dp"
            android:textAllCaps="true"
            android:textColor="#F44336"
            app:strokeColor="#F44336"
            app:cornerRadius="8dp" />

        <!-- Add More Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddMore"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Add More"
            android:textAllCaps="true"
            android:textSize="24dp"
            android:textColor="#FF9800"
            app:strokeColor="#FF9800"
            app:cornerRadius="8dp" />

        <!-- Submit Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubmitResults"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Submit"
            android:textAllCaps="true"
            android:textSize="24sp"
            app:backgroundTint="@color/teacher_primary"
            app:cornerRadius="8dp" />
    </LinearLayout>

</LinearLayout>