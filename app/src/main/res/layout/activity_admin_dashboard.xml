<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.coordinatorlayout.widget.CoordinatorLayout
            android:id="@+id/coordinatorLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@id/bottomNavigation">

            <!-- Toolbar -->
            <com.google.android.material.appbar.AppBarLayout
                android:layout_width="wrap_content"
                android:layout_height="150dp"
                android:background="@color/primary_blue"
                app:elevation="0dp">

                <androidx.appcompat.widget.Toolbar
                    android:id="@+id/toolbar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:contentInsetStart="0dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="90dp"
                        android:paddingHorizontal="32dp">

                        <ImageView
                            android:id="@+id/btnMenu"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_centerVertical="true"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="menu"
                            android:padding="4dp"
                            android:src="@drawable/ic_menu"
                            app:tint="@color/white" />

                        <ImageView
                            android:id="@+id/ivSchoolLogo"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="8dp"
                            android:layout_toEndOf="@id/btnMenu"
                            android:contentDescription="schoolLogo"
                            android:src="@drawable/st_louis" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="8dp"
                            android:layout_toEndOf="@id/ivSchoolLogo"
                            android:text="St. Louis"
                            android:textColor="@color/white"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/btnNotifications"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="8dp"
                            android:layout_toStartOf="@id/btnSearch"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:padding="6dp"
                            android:src="@drawable/ic_notification"
                            app:tint="@color/white" />

                        <ImageView
                            android:id="@+id/btnSearch"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:padding="6dp"
                            android:src="@drawable/search"
                            app:tint="@color/white" />

                    </RelativeLayout>
                </androidx.appcompat.widget.Toolbar>
            </com.google.android.material.appbar.AppBarLayout>

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_behavior="@string/appbar_scrolling_view_behavior">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Profile Header -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/primary_blue"
                        android:padding="16dp">

                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:cardBackgroundColor="#1E40AF"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="8dp">

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:padding="24dp">

                                <TextView
                                    android:id="@+id/tvGreeting"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Good morning,"
                                    android:textColor="#BFDBFE"
                                    android:textSize="14sp" />

                                <TextView
                                    android:id="@+id/tvAdminName"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_below="@id/tvGreeting"
                                    android:layout_marginTop="4dp"
                                    android:text="Dr. James Mutua"
                                    android:textColor="@color/white"
                                    android:textSize="22sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvAdminRole"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_below="@id/tvAdminName"
                                    android:layout_marginTop="2dp"
                                    android:text="School Principal"
                                    android:textColor="#93C5FD"
                                    android:textSize="14sp" />

                                <TextView
                                    android:id="@+id/tvAvatar"
                                    android:layout_width="56dp"
                                    android:layout_height="56dp"
                                    android:layout_alignParentEnd="true"
                                    android:background="@drawable/bg_term_badge"
                                    android:backgroundTint="#3B82F6"
                                    android:gravity="center"
                                    android:text="JM"
                                    android:textColor="@color/white"
                                    android:textSize="22sp"
                                    android:textStyle="bold" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_below="@id/tvAdminRole"
                                    android:layout_marginTop="20dp"
                                    android:orientation="horizontal"
                                    android:weightSum="2">

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:layout_marginEnd="8dp"
                                        android:background="@drawable/bg_term_badge"
                                        android:backgroundTint="#3B82F6"
                                        android:orientation="vertical"
                                        android:padding="12dp">
                                        <TextView
                                            android:text="Today's Date"
                                            android:layout_height="wrap_content"
                                            android:layout_width="wrap_content"
                                            android:textColor="#BFDBFE"
                                            android:textSize="12sp" />
                                        <TextView
                                            android:id="@+id/tvCurrentDate"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="Mon, 13 Jun 2026"
                                            android:textColor="@color/white"
                                            android:textSize="15sp"
                                            android:textStyle="bold" />
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:layout_marginStart="8dp"
                                        android:background="@drawable/bg_term_badge"
                                        android:backgroundTint="#3B82F6"
                                        android:orientation="vertical"
                                        android:padding="12dp">
                                        <TextView
                                            android:text="School Term"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:textColor="#BFDBFE"
                                            android:textSize="12sp" />
                                        <TextView
                                            android:id="@+id/tvTermInfo"
                                            android:layout_height="wrap_content"
                                            android:layout_width="wrap_content"
                                            android:text="Term 2 — Week 8"
                                            android:textColor="@color/white"
                                            android:textSize="15sp"
                                            android:textStyle="bold" />
                                    </LinearLayout>
                                </LinearLayout>
                            </RelativeLayout>
                        </androidx.cardview.widget.CardView>
                    </RelativeLayout>

                    <!-- Main Content -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Overview -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp">
                            <TextView
                                android:text="Overview"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_title"/>
                            <TextView
                                android:text="View all"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:textColor="@color/primary_blue"
                                android:textSize="14sp"/>
                        </RelativeLayout>

                        <!-- Stats Cards -->
                        <GridLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:columnCount="2"
                            android:rowCount="2"
                            android:horizontalSpacing="12dp"
                            android:verticalSpacing="12dp">

                            <!-- Students Card -->
                            <androidx.cardview.widget.CardView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                app:cardCornerRadius="16dp"
                                app:cardElevation="2dp">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:padding="16dp">
                                    <ImageView
                                        android:layout_width="32dp"
                                        android:layout_height="32dp"
                                        android:src="@drawable/ic_students"
                                        app:tint="@color/primary_blue"
                                        android:layout_marginBottom="8dp"/>
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Total Students"
                                        android:textColor="@color/text_secondary"
                                        android:textSize="12sp" />
                                    <TextView
                                        android:id="@+id/tvStudentCount"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="942"
                                        android:textColor="@color/text_title"
                                        android:textSize="20sp"
                                        android:textStyle="bold" />
                                </LinearLayout>
                            </androidx.cardview.widget.CardView>

                            <!-- Staff Card -->
                            <androidx.cardview.widget.CardView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                app:cardCornerRadius="16dp"
                                app:cardElevation="2dp">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:padding="16dp">
                                    <ImageView
                                        android:layout_width="32dp"
                                        android:layout_height="32dp"
                                        android:src="@drawable/ic_active"
                                        app:tint="@color/primary_purple"
                                        android:layout_marginBottom="8dp"/>
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Active Staff"
                                        android:textColor="@color/text_secondary"
                                        android:textSize="12sp" />
                                    <TextView
                                        android:id="@+id/tvStaffCount"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="48"
                                        android:textColor="@color/text_title"
                                        android:textSize="20sp"
                                        android:textStyle="bold" />
                                </LinearLayout>
                            </androidx.cardview.widget.CardView>

                            <!-- Attendance Card -->
                            <androidx.cardview.widget.CardView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                app:cardCornerRadius="16dp"
                                app:cardElevation="2dp">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:padding="16dp">
                                    <ImageView
                                        android:layout_width="32dp"
                                        android:layout_height="32dp"
                                        android:src="@drawable/ic_attendence"
                                        app:tint="@color/success"
                                        android:layout_marginBottom="8dp"/>
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Attendance"
                                        android:textColor="@color/text_secondary"
                                        android:textSize="12sp" />
                                    <TextView
                                        android:id="@+id/tvAttendanceRate"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="96%"
                                        android:textColor="@color/success"
                                        android:textSize="20sp"
                                        android:textStyle="bold" />
                                </LinearLayout>
                            </androidx.cardview.widget.CardView>

                            <!-- Fees Card -->
                            <androidx.cardview.widget.CardView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                app:cardCornerRadius="16dp"
                                app:cardElevation="2dp">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:padding="16dp">
                                    <ImageView
                                        android:layout_width="32dp"
                                        android:layout_height="32dp"
                                        android:src="@drawable/ic_fees"
                                        app:tint="@color/primary_orange"
                                        android:layout_marginBottom="8dp"/>
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Fees Collected"
                                        android:textColor="@color/text_secondary"
                                        android:textSize="12sp" />
                                    <TextView
                                        android:id="@+id/tvFeesCollected"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="72%"
                                        android:textColor="@color/primary_blue"
                                        android:textSize="20sp"
                                        android:textStyle="bold" />
                                </LinearLayout>
                            </androidx.cardview.widget.CardView>

                        </GridLayout>

                        <!-- Enrollment Trend -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="24dp"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="2dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="16dp">

                                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="Enrollment Trend"
                                        android:textSize="16sp"
                                        android:textStyle="bold"
                                        android:textColor="@color/text_title"/>
                                    <TextView
                                        android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                        android:text="2026"
                                        android:layout_alignParentEnd="true"
                                        android:background="@drawable/bg_term_badge" android:backgroundTint="#F1F5F9" android:padding="8dp" android:textSize="12sp"/>
                                </RelativeLayout>

                                <com.github.mikephil.charting.charts.LineChart
                                    android:id="@+id/enrollmentChart"
                                    android:layout_width="match_parent"
                                    android:layout_height="200dp"
                                    android:layout_marginTop="16dp"/>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <!-- Fee Collection Donut -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="24dp"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="2dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="16dp">

                                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                                    <TextView
                                        android:text="Fee Collection Status"
                                        android:textSize="16sp"
                                        android:textStyle="bold"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:textColor="@color/text_title"/>
                                </RelativeLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="180dp"
                                    android:layout_marginTop="16dp"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal">

                                    <com.github.mikephil.charting.charts.PieChart
                                        android:id="@+id/feeDonutChart"
                                        android:layout_width="140dp"
                                        android:layout_height="140dp" />

                                    <!-- Legend -->
                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="24dp"
                                        android:orientation="vertical">

                                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                                            <View android:layout_width="12dp" android:layout_height="12dp" android:background="@color/success"/>
                                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Paid (68%)" android:layout_marginStart="8dp" android:textSize="12sp"/>
                                        </LinearLayout>

                                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                                            <View android:layout_width="12dp" android:layout_height="12dp" android:background="#FF9800"/>
                                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Partial (18%)" android:layout_marginStart="8dp" android:textSize="12sp"/>
                                        </LinearLayout>

                                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                                            <View android:layout_width="12dp" android:layout_height="12dp" android:background="@color/error"/>
                                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pending (14%)" android:layout_marginStart="8dp" android:textSize="12sp"/>
                                        </LinearLayout>

                                    </LinearLayout>
                                </LinearLayout>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <!-- Quick Actions -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="24dp"
                            android:text="Quick Actions"
                            android:textColor="@color/text_title"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <GridLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:columnCount="3"
                            android:rowCount="2">

                            <LinearLayout
                                android:id="@+id/btnAddStudent"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="12dp"
                                android:background="?attr/selectableItemBackground">
                                <ImageView
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:background="@drawable/circular_bg"
                                    android:backgroundTint="#EEF2FF"
                                    android:padding="8dp"
                                    android:src="@drawable/ic_add_person"
                                    app:tint="@color/primary_blue" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="Add Student"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_body"/>
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/btnTimetable"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="12dp"
                                android:background="?attr/selectableItemBackground">
                                <ImageView
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:background="@drawable/circular_bg"
                                    android:backgroundTint="#F0FDF4"
                                    android:padding="8dp"
                                    android:src="@drawable/ic_schedule"
                                    app:tint="@color/success" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="Timetable"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_body"/>
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/btnSendNotice"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="12dp"
                                android:background="?attr/selectableItemBackground">
                                <ImageView
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:background="@drawable/circular_bg"
                                    android:backgroundTint="#FFFBEB"
                                    android:padding="8dp"
                                    android:src="@drawable/ic_send"
                                    app:tint="@color/warning" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="Send Notice"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_body"/>
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/btnReportsQuick"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="12dp"
                                android:background="?attr/selectableItemBackground">
                                <ImageView
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:background="@drawable/circular_bg"
                                    android:backgroundTint="#FAF5FF"
                                    android:padding="8dp"
                                    android:src="@drawable/ic_reports"
                                    app:tint="@color/primary_purple" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="Reports"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_body"/>
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/btnFeeSetup"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="12dp"
                                android:background="?attr/selectableItemBackground">
                                <ImageView
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:background="@drawable/circular_bg"
                                    android:backgroundTint="#FEF2F2"
                                    android:padding="8dp"
                                    android:src="@drawable/ic_fees"
                                    app:tint="@color/error" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="Fees"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_body"/>
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/btnAttendance"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="12dp"
                                android:background="?attr/selectableItemBackground">
                                <ImageView
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:background="@drawable/circular_bg"
                                    android:backgroundTint="#ECFEFF"
                                    android:padding="8dp"
                                    android:src="@drawable/ic_attendence"
                                    app:tint="@color/primary_teal" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="Attendance"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_body"/>
                            </LinearLayout>

                        </GridLayout>

                    </LinearLayout>
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </androidx.coordinatorlayout.widget.CoordinatorLayout>

        <!-- Bottom Nav -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavigation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:background="@color/white"
            app:elevation="8dp"
            app:itemIconTint="@color/primary_blue"
