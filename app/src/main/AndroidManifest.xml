<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@drawable/st_louis"
        android:label="@string/app_name"
        android:roundIcon="@drawable/st_louis"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.Light.NoActionBar">

        <!-- Launcher: Splash Screen -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Authentication -->
        <activity android:name=".LoginActivity" android:exported="false" />
        <activity android:name=".ForgotPasswordActivity" android:exported="false" />

        <!-- Admin Management Portals -->
        <activity android:name=".ui.admin.AdminDashboardActivity" android:exported="false" />
        <activity android:name=".ui.admin.StudentManagementActivity" android:exported="false" />
        <activity android:name=".ui.admin.TeacherManagementActivity" android:exported="false" />
        <activity android:name=".ui.admin.BursarManagementActivity" android:exported="false" />
        <activity android:name=".ui.admin.ManageUsersActivity" android:exported="false" />
        <activity android:name=".ui.admin.TimetableManagementActivity" android:exported="false" />
        <activity android:name=".ui.admin.FinanceManagementActivity" android:exported="false" />
        <activity android:name=".ui.admin.ReportsActivity" android:exported="false" />
        <activity android:name=".ui.admin.SettingsActivity" android:exported="false" />

        <!-- User Role Dashboards -->
        <activity android:name=".ui.teacher.TeacherDashboardActivity" android:exported="false" />
        <activity android:name=".ui.student.StudentDashboardActivity" android:exported="false" />
        <activity android:name=".ui.bursar.BursarDashboardActivity" android:exported="false" />
        <activity android:name=".ui.parent.ParentDashboardActivity" android:exported="false" />

        <activity android:name=".MainActivity" android:exported="false" />

    </application>

</manifest>
